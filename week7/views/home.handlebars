<h1>{{title}}</h1>
<p>{{description}}</p>

{{!-- Slideshow with the homepage gallery --}}
<div id="carouselHome" class="carousel slide" data-bs-ride="carousel">
  <div class="carousel-inner">
    {{#each galleryImages}}
    <div class="carousel-item {{#if @first}}active{{/if}}">
      {{!-- widescreen class handles the sizing in your master.css --}}
      <img class="widescreen d-block w-100" src="{{url}}" alt="{{caption}}">
      
      {{!-- This block makes your captions visible on the images --}}
      <div class="carousel-caption d-none d-md-block" style="background: rgba(0,0,0,0.5); border-radius: 10px;">
        <p>{{caption}}</p>
      </div>
    </div>
    {{/each}}
  </div>

  {{!-- Carousel Controls --}}
  <button class="carousel-control-prev" type="button" data-bs-target="#carouselHome" data-bs-slide="prev">
    <span class="carousel-control-prev-icon" aria-hidden="true"></span>
    <span class="visually-hidden">Previous</span>
  </button>
  <button class="carousel-control-next" type="button" data-bs-target="#carouselHome" data-bs-slide="next">
    <span class="carousel-control-next-icon" aria-hidden="true"></span>
    <span class="visually-hidden">Next</span>
  </button>
</div>

{{!-- Destinations Section --}}
<div class="row mt-5">
  <h2 class="mb-4">Explore Destinations</h2>
  {{#each destinations}}
  <div class="col col-4 mb-4">
    <div class="card h-100">
      {{!-- square class ensures all cards look uniform --}}
      <img src="{{image}}" class="card-img-top img-fluid square" alt="{{name}} image">
      <div class="card-body d-flex flex-column">
        <h5 class="card-title">{{name}}</h5>
        <p class="card-text text-truncate">{{description}}</p>
        <a href="/destinations/{{_id}}" class="btn btn-primary mt-auto">View Details</a>
      </div>
    </div>
  </div>
  {{/each}}
</div>